        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//Verifies API returned HTTP 200 (OK)",
                  "pm.test(\"Login Successful\", function(){pm.response.to.have.status(200)});",
                  "//Converts response body → JSON object",
                  "let res = pm.response.json();",
                  "//Saves token into environment variable",
                  "pm.environment.set(\"token\",res.token);",
                  "// Validate token",
                  "pm.test(\"Token is set\", function(){pm.expect(pm.environment.get(\"token\")).to.not.be.null});",
                  "",
                  "//Validate response time is less than 500ms",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "//Summary log",
                  "console.log(\"=== Validation Summary ===\");",
                  "console.log(\"Token: \" + res.token);",
                  "console.log(\"Response time: \" + pm.response.responseTime + \"ms\");",
                  "console.log(\"Status code: \" + pm.response.code);",
                  "console.log(\"=== End of Validation Summary ===\");"
                ],
