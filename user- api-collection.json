        {
          "name": "Update User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse response\r",
                  "let res = pm.response.json();\r",
                  "\r",
                  "// 1. Status code check\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Response time check\r",
                  "pm.test(\"Response time < 500ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                  "});\r",
                  "\r",
                  "// 3. Validate updated name\r",
                  "pm.test(\"Name is updated correctly\", function () {\r",
                  "    pm.expect(res.name).to.eql(pm.request.body.raw ? JSON.parse(pm.request.body.raw).name : undefined);\r",
                  "});\r",
                  "\r",
                  "// 4. Validate updated job\r",
                  "pm.test(\"Job is updated correctly\", function () {\r",
                  "    pm.expect(res.job).to.eql(JSON.parse(pm.request.body.raw).job);\r",
                  "});\r",
                  "\r",
                  "// 5. Validate response has updated timestamp (if API supports it)\r",
                  "pm.test(\"Response contains updatedAt\", function () {\r",
                  "    pm.expect(res.updatedAt).to.not.be.undefined;\r",
                  "});\r",
                  "//Save updated user ID:\r",
                  "pm.environment.set(\"userId\", res.id || pm.environment.get(\"userId\"));\r",
                  "\r",
                  "// 6. Log summary\r",
                  "console.log(\"=== Update User Summary ===\");\r",
                  "console.log(\"Status code: \" + pm.response.code);\r",
                  "console.log(\"Response time: \" + pm.response.responseTime + \"ms\");\r",
                  "console.log(\"Updated name: \" + res.name);\r",
                  "console.log(\"Updated job: \" + res.job);\r",
                  "console.log(\"=== End ===\");"
                ],
