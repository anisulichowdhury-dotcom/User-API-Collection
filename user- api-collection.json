        {
          "name": "Get Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//Verifies API returned HTTP 200 (OK)\r",
                  "pm.test(\"Login Successful\", function(){pm.response.to.have.status(200)});\r",
                  "//Converts response body → JSON object\r",
                  "let res = pm.response.json();\r",
                  "//Validate response time is less than 500ms\r",
                  "pm.test(\"Response time is less than 500ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                  "});\r",
                  "\r",
                  "//Validate ID count\r",
                  "let idCount = 0;\r",
                  "\r",
                  "pm.test(\"Validate total id count\", function () {\r",
                  "    if (Array.isArray(res)) {\r",
                  "        idCount = res.filter(item => item.hasOwnProperty(\"id\")).length;\r",
                  "        pm.expect(idCount).to.equal(res.length);\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "//Validate user data exists in response body\r",
                  "pm.test(\"Users exist\", () => {\r",
                  "    pm.expect(res.data.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "//Summary log\r",
                  "console.log(\"=== Validation Summary ===\");\r",
                  "console.log(\"Response time: \" + pm.response.responseTime + \"ms\");\r",
                  "console.log(\"Status code: \" + pm.response.code);\r",
                  "console.log(\"Total id count: \" + idCount);\r",
                  "console.log(\"=== End of Validation Summary ===\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
